flowchart TD
    %% spell:ignore mrfootoyou dasharray kmuc ghillie Mjolnir

    %% TACTICAL CLASS DEFINITIONS
    classDef default fill:#1e293b,color:#f8fafc,stroke:#475569,stroke-width:1px
    classDef action fill:#475569,color:#ffffff,stroke:#1e293b,stroke-width:1px
    classDef place fill:#0f172a,color:#38bdf8,stroke:#0ea5e9,stroke-width:2px
    classDef endgame_loot fill:#eab308,color:#422006,stroke:#854d0e,stroke-width:3px
    classDef quest_loot fill:#22c55e,color:#052e16,stroke:#14532d,stroke-width:2px
    classDef optional_loot fill:#64748b,color:#f1f5f9,stroke:#475569,stroke-dasharray: 5 5
    classDef terminal fill:#fbbf24,color:#000000,stroke:#d97706,stroke-width:4px

    subgraph flowchart_key ["`**TACTICAL KEY**`"]
        direction LR
        k_endgame[Endgame Items]
        k_quest[Quest Items]
        k_opt[Optional Items]
        k_loc([Location / Gate])
        k_act[/Action / Craft/]

        k_endgame ~~~ k_quest
        k_quest ~~~ k_opt
        k_opt ~~~ k_loc
        k_loc ~~~ k_act

        class k_endgame endgame_loot
        class k_quest quest_loot
        class k_opt optional_loot
        class k_loc place
        class k_act action
    end
    %% Place at top (above spawn) for easy reference
    flowchart_key ~~~ spawn

    spawn(["`**SPAWN 🏁**`"])
    spawn ==> |find|dive_suit
    spawn ==> |collect|nbc_suit
    spawn ==> |travel|swamp_temple_teleport
    spawn ==> |find|purple_keycard
    spawn ==> |find|ghillie

    %% NON-LOCALIZED UTILITY
    light_source[Light Source 🔦]
    class light_source optional_loot

    subgraph northeast ["`**NORTHEAST ISLES 🏝️**`"]
        direction LR
        air_compressor[Air Compressor 💨]
        dive_suit[Diving Suit 🤿]
        beacon_tracker[Beacon Tracker 📡]
        dive_loot[Dive Loot 💎]
    end
    air_compressor --> |refill|dive_suit
    dive_suit --> |submerge|dive_loot
    beacon_tracker -.-> |locate|dive_loot

    subgraph swamp_area ["`**SWAMP 🍄**`"]
        direction LR
        swamp_temple_teleport([Temple Teleport 🌀])
        nbc_suit[NBC Suit ☢️]
    end
    swamp_temple_teleport ==> |teleport|temple_main

    subgraph alcatraz ["`**ALCATRAZ ⛓️**`"]
        purple_keycard[Purple Keycard 🟪]
    end

    subgraph craft_ghillie ["`**CRAFT: GHILLIE 🌿**`"]
        direction LR
        burlap[Burlap Strips 10x]
        netting[Netting 4x]
        make_ghillie[/Combine 🛠️/]
        ghillie[Ghillie 🌿]
    end
    burlap --x make_ghillie
    netting --x make_ghillie
    make_ghillie --> ghillie

    subgraph craft_bear ["`**CRAFT: BEAR GHILLIE 🐻**`"]
        direction LR
        bear_pelts[Bear Pelts 2x]
        leather_kit[Leather Kit 🪡]
        tanned_bear_pelts[Tanned Pelts]
        prepare_bear_pelts[/Tan Hides 🔨/]
        make_bear_suit[/Stitch Suit 🪡/]
        bear_suit[Bear Ghillie 🐻]
    end
    bear_pelts --x prepare_bear_pelts
    leather_kit --x prepare_bear_pelts
    prepare_bear_pelts --> tanned_bear_pelts
    tanned_bear_pelts --x make_bear_suit
    ghillie --x make_bear_suit
    make_bear_suit --> bear_suit

    subgraph crater ["`**CRATER ISLAND 🌋**`"]
        crater_tower([Crater Tower 🗼])
        smoke_orb[X65 Smoke Orb 💨]
    end
    crater_tower --> smoke_orb
    nbc_suit --> |protect|crater_tower

    subgraph kmuc_entry ["`**KMUC 🏔️**`"]
        kmuc_blast_door([Blast Door 🔒])
        staff[Staff 🪄]
    end
    light_source -.-> |see|kmuc_blast_door
    purple_keycard --x |unlock|kmuc_blast_door
    kmuc_blast_door --> staff

    smoke_monster([Smoke Monster 💨])
    smoke_orb --x |conjure|smoke_monster
    staff --> |tame|smoke_monster
    smoke_monster ==> |teleport|temple_secondary

    subgraph old_temple ["`**OLD TEMPLE 🏛️**`"]
        temple_dive_entry([Underwater Entry 🌊])
        punch_card[Punch Card 💾]
        temple_main([Main Temple 🛕])
        temple_secondary([Handle Area 🧭])
        temple_swamp_teleport([Swamp Teleport 🌀])
        temple_flame([Flame Room 🔥])
        temple_endgame_teleport([Endgame Teleport ⚡])
        hammer_head[Hammer Head ⚒️]
        hammer_handle[Hammer Handle 🦴]
        make_hammer[/Forge ⚒️/]
        hammer[Mjolnir Hammer]
    end
    dive_suit --> |dive|temple_dive_entry
    temple_dive_entry --> punch_card
    temple_dive_entry ==> temple_main
    temple_main ==> temple_swamp_teleport
    temple_swamp_teleport ==> swamp_area
    temple_main ==> temple_flame
    temple_flame ==> temple_endgame_teleport
    eternal_staff --> |ignite|temple_flame
    temple_endgame_teleport ==> kmuc2_blast_door
    temple_main --> hammer_head
    light_source -.-> |illuminate|temple_secondary
    temple_secondary --> hammer_handle
    hammer_head --x make_hammer
    hammer_handle --x make_hammer
    make_hammer --> hammer

    subgraph crypt ["`**THE CRYPT ❄️**`"]
        crypt_door([Crypt Door 🧱])
        green_keycard[Green Keycard 🟩]
        eternal_flame([Eternal Flame 🔥])
        eternal_staff[Eternal Staff 🔱]
    end
    hammer --x |smash|crypt_door
    crypt_door --> green_keycard
    crypt_door ==> eternal_flame
    staff --x |whack|eternal_flame
    eternal_flame --> eternal_staff

    subgraph carrier ["`**AIRCRAFT CARRIER ⛴️**`"]
        carrier_loot[High Tier Loot 🔫]
    end
    nbc_suit --> |protect|carrier_loot
    green_keycard --x |unlock|carrier_loot

    subgraph kmuc_endgame ["`**KMUC ENDGAME 🙃**`"]
        kmuc2_blast_door([Blast Door 🔒])
        endgame_reactor([Reactor Room ☢️])
        endgame[[**ENDGAME 🏆**]]
    end
    purple_keycard --x |unlock|kmuc2_blast_door
    kmuc2_blast_door ==> endgame_reactor
    punch_card --x |authorize|endgame_reactor
    endgame_reactor ==> endgame
    eternal_staff --> |activate|endgame
    bear_suit --> |survive|endgame

    %% ASSIGN CLASSES
    class spawn,swamp_temple_teleport,crater_tower,kmuc_blast_door,crypt_door,eternal_flame place
    class temple_dive_entry,temple_main,temple_secondary,temple_flame,temple_swamp_teleport,temple_endgame_teleport place
    class kmuc2_blast_door,endgame_reactor place
    class smoke_monster place

    class nbc_suit,leather_kit,bear_pelts,ghillie quest_loot
    class dive_suit,air_compressor,hammer_head,hammer_handle,hammer quest_loot
    class staff,smoke_orb quest_loot

    class purple_keycard,punch_card,eternal_staff,bear_suit endgame_loot

    class beacon_tracker,dive_loot,green_keycard,carrier_loot,netting,burlap optional_loot

    class make_ghillie,make_bear_suit,prepare_bear_pelts,make_hammer action

    class endgame terminal
